<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Peanut · 韩旺乎 | 英雄联盟传奇打野</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', system-ui, -apple-system, 'Segoe UI', 'Roboto', 'Noto Sans SC', monospace;
            background: #0a0c10;
            color: #e0e0e0;
            line-height: 1.5;
            scroll-behavior: smooth;
            position: relative;
        }

        /* 电竞风格网格背景 */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 255, 255, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .main-wrapper {
            max-width: 1300px;
            margin: 0 auto;
            padding: 1.5rem;
            position: relative;
            z-index: 2;
        }

        /* 导航栏 暗黑科技风 */
        .navbar {
            background: rgba(10, 15, 25, 0.9);
            backdrop-filter: blur(12px);
            border-radius: 60px;
            padding: 0.7rem 2rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            border: 1px solid #2a3a5a;
            box-shadow: 0 0 15px rgba(0, 200, 255, 0.1);
        }

        .logo {
            font-weight: 800;
            font-size: 1.4rem;
            background: linear-gradient(135deg, #ff7e5e, #feb47b);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .nav-links a {
            text-decoration: none;
            color: #b0d4ff;
            font-weight: 600;
            transition: 0.2s;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .nav-links a:hover {
            color: #ffaa66;
            text-shadow: 0 0 5px #ffaa66;
        }

        /* 英雄区 Hero */
        .hero {
            background: linear-gradient(145deg, #0f172f 0%, #0a0f1a 100%);
            border-radius: 2rem;
            padding: 2.5rem;
            margin-bottom: 2.5rem;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            border: 1px solid #2c3e66;
            box-shadow: 0 20px 35px rgba(0,0,0,0.5);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: "⚡🐯";
            font-size: 140px;
            position: absolute;
            bottom: -30px;
            right: -20px;
            opacity: 0.1;
            pointer-events: none;
        }

        .hero-info h1 {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #ffcc88, #ff8c5a);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.2rem;
        }

        .hero-tag {
            display: inline-block;
            background: #1e2a3a;
            color: #ffaa66;
            padding: 0.3rem 1.2rem;
            border-radius: 30px;
            font-size: 0.8rem;
            font-weight: 700;
            margin: 0.8rem 0;
            border: 1px solid #ffaa66;
        }

        .hero-info p {
            color: #c0d4f0;
            max-width: 550px;
            margin-bottom: 0.5rem;
        }

        .hero-avatar {
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, #2a3a50, #0a0f1a);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 5rem;
            border: 3px solid #ffaa66;
            box-shadow: 0 0 30px rgba(255, 170, 102, 0.3);
            animation: borderGlow 2s infinite;
        }

        @keyframes borderGlow {
            0% { box-shadow: 0 0 0 0 rgba(255, 170, 102, 0.4); border-color: #ffaa66; }
            50% { box-shadow: 0 0 0 12px rgba(255, 170, 102, 0.1); border-color: #ffdd99; }
            100% { box-shadow: 0 0 0 0 rgba(255, 170, 102, 0); border-color: #ffaa66; }
        }

        /* 通用卡片 */
        .section {
            margin-bottom: 2.8rem;
        }

        .section-title {
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1.5rem;
            border-left: 5px solid #ffaa66;
            padding-left: 1rem;
            color: #ffddbb;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .card {
            background: rgba(18, 25, 45, 0.7);
            backdrop-filter: blur(4px);
            border-radius: 1.5rem;
            padding: 1.3rem;
            border: 1px solid #2a3a55;
            transition: all 0.25s;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: #ffaa66;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            background: rgba(25, 35, 60, 0.85);
        }

        .card h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            color: #ffcc88;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .badge {
            background: #1e2a3a;
            padding: 0.2rem 0.8rem;
            border-radius: 30px;
            font-size: 0.7rem;
            color: #ffaa66;
            display: inline-block;
            margin-bottom: 0.8rem;
        }

        .achievement-list {
            list-style: none;
            padding-left: 0;
        }
        .achievement-list li {
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
        }

        .champion-icon {
            font-size: 1.2rem;
        }

        .stat-bar {
            background: #1e2a3a;
            border-radius: 20px;
            height: 8px;
            margin: 8px 0;
            overflow: hidden;
        }
        .stat-fill {
            background: linear-gradient(90deg, #ffaa66, #ff7e5e);
            width: 90%;
            height: 100%;
            border-radius: 20px;
        }

        footer {
            text-align: center;
            margin-top: 2rem;
            padding: 1.5rem;
            background: #0d1422cc;
            border-radius: 2rem;
            border: 1px solid #2a3a55;
            font-size: 0.75rem;
        }

        @media (max-width: 700px) {
            .hero {
                flex-direction: column-reverse;
                text-align: center;
            }
            .navbar {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
<div class="main-wrapper">
